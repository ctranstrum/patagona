{
  "name": "patagona",
  "version": "1.0.0",
  "description": "Patagona Wireless Keyboard Design",
  "main": "index.js",
  "scripts": {
    "all": "npm run clean-all ; npm run ergo && npm run stl",
    "clean-all": "rm -rf output",
    "clean-cases": "rm -rf output/cases",
    "clean-outlines": "rm -rf output/outlines",
    "clean-pcbs": "rm -rf output/pcbs",
    "save-pcb": "cp output/pcbs/* pcb",
    "save-cases": "cp output/cases/*.stl cases",
    "ergo": "ergogen .",
    "stl": "for i in output/cases/*.jscad; do npx @jscad/cli@1 \"$i\" -of stla; done",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "32 keys",
    "5-way switch",
    "gateron low profile",
    "hummingbird",
    "patagona gigas",
    "wireless keyboard",
    "xiao nrf52840",
    "zmk"
  ],
  "author": "Chad Transtrum <chad@transtrum.net>",
  "license": "CERN-OHL-P-2.0",
  "devDependencies": {
    "@jscad/cli": "^1.10.0",
    "ergogen": "^4.1.0",
    "prettier": "^3.4.2"
  }
}
